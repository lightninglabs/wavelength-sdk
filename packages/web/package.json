{
  "name": "@lightninglabs/wavelength-web",
  "version": "0.0.0",
  "private": false,
  "description": "Browser (WebAssembly) transport for the Wavelength self-custodial Lightning wallet SDK.",
  "license": "MIT",
  "homepage": "https://wavelength.lightning.engineering",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lightninglabs/wavelength-sdk.git",
    "directory": "packages/web"
  },
  "bugs": "https://github.com/lightninglabs/wavelength-sdk/issues",
  "keywords": ["lightning", "bitcoin", "wallet", "self-custodial", "payments", "webassembly", "wasm"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wavewalletdk-worker.js": "./dist/wavewalletdk-worker.js"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/wavewalletdk-worker.js dist/wavewalletdk-worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@lightninglabs/wavelength-core": "workspace:*"
  },
  "files": ["dist"]
}
