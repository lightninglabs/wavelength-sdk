{
  "name": "@lightninglabs/wavelength-react-native",
  "version": "0.1.0",
  "private": false,
  "description": "React Native transport for the Wavelength self-custodial Lightning wallet SDK.",
  "license": "MIT",
  "homepage": "https://wavelength.lightning.engineering",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lightninglabs/wavelength-sdk.git",
    "directory": "packages/react-native"
  },
  "bugs": "https://github.com/lightninglabs/wavelength-sdk/issues",
  "keywords": ["lightning", "bitcoin", "wallet", "self-custodial", "payments", "react-native"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "fetch-bindings": "bash scripts/fetch-bindings.sh"
  },
  "codegenConfig": {
    "name": "WavelengthSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "engineering.lightning.wavelength.reactnative"
    }
  },
  "dependencies": {
    "@lightninglabs/wavelength-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "devDependencies": {
    "react-native": "0.86.0",
    "@types/react": "^19.2.17",
    "react": "19.2.3"
  },
  "files": ["dist", "src", "android", "ios", "*.podspec", "!android/libs", "!ios/Wavewalletdk.xcframework"]
}
