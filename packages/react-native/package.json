{
  "name": "@lightninglabs/wavelength-react-native",
  "version": "0.0.0",
  "private": false,
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "fetch-bindings": "bash scripts/fetch-bindings.sh"
  },
  "codegenConfig": {
    "name": "WalletdkSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "engineering.lightning.walletdk.reactnative"
    }
  },
  "dependencies": {
    "@lightninglabs/wavelength-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "devDependencies": {
    "react-native": "0.86.0",
    "@types/react": "^19.2.17",
    "react": "19.2.3"
  },
  "files": ["dist", "src", "android", "ios", "*.podspec", "!android/libs", "!ios/Walletdk.xcframework"]
}
