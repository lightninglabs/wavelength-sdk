---
/**
 * Sidebar.astro - Left navigation sidebar with section dividers and per-section
 * accent dots. Ported from design-mockups/r4-final/styles.css (.sidebar-*).
 *
 * Props:
 *   currentSlug - the slug of the currently active page (e.g. "web/get-started/quickstart").
 */
import { SECTION_ACCENT, accentForSlug, sliceForSlug } from '~/config/nav';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

// Resolve the accent color for the currently active slug.
const activeAccent = accentForSlug(currentSlug);
const groups = sliceForSlug(currentSlug).nav;
---

<nav class="wdk-sidebar" aria-label="Documentation navigation">
  {groups.map((group) => {
    const groupAccent = SECTION_ACCENT[group.section] ?? 'violet';
    return (
      <div class="wdk-sidebar__section">
        <div class="wdk-sidebar__divider" aria-hidden="true">
          <span
            class="wdk-sidebar__dot"
            style={`background: var(--${groupAccent})`}
          ></span>
          {group.label}
        </div>
        {group.items.map((item) => {
          const isActive = item.slug === currentSlug;
          return (
            <a
              href={`/${item.slug}/`}
              class:list={[
                'wdk-sidebar__link',
                isActive && 'wdk-sidebar__link--active',
                isActive && `wdk-sidebar__link--${activeAccent}`,
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </div>
    );
  })}
</nav>

<script>
  // Preserve the sidebar's scroll position across client-side navigations. The
  // sidebar re-renders per page (to move the active-link highlight), so without
  // this it snaps back to the top on every click. Capture the offset just
  // before the body swaps out and reapply it to the freshly rendered sidebar.
  // Register once (inline scripts replay on each swap; the window flag keeps the
  // listeners from stacking). `saved` stays null on a fresh full load, so only
  // an actual in-app navigation restores, never a first paint.
  if (!window.__wdkSidebarScrollBound) {
    window.__wdkSidebarScrollBound = true;
    let saved: number | null = null;
    document.addEventListener('astro:before-swap', () => {
      const el = document.querySelector('.wdk-sidebar');
      saved = el ? el.scrollTop : null;
    });
    document.addEventListener('astro:page-load', () => {
      if (saved === null) return;
      const el = document.querySelector('.wdk-sidebar');
      if (el) el.scrollTop = saved;
      saved = null;
    });
  }
</script>

<style>
  /* Sidebar container - fixed, full-height, with thin scrollbar. */
  .wdk-sidebar {
    position: fixed;
    top: var(--header-height, 56px);
    left: 0;
    bottom: 0;
    width: var(--sidebar-w, 256px);
    background: var(--rail-bg);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    padding: 24px 0 40px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    z-index: 50;
  }

  .wdk-sidebar::-webkit-scrollbar { width: 4px; }
  .wdk-sidebar::-webkit-scrollbar-track { background: transparent; }
  .wdk-sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  /* Each section block. */
  .wdk-sidebar__section {
    margin-top: 4px;
  }
  .wdk-sidebar__section:first-child {
    margin-top: 0;
  }

  /* Section divider: accent dot + label text + trailing line. */
  .wdk-sidebar__divider {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 18px 14px 7px;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .wdk-sidebar__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
    margin-left: 4px;
  }

  /* Accent dot - 7x7 rounded square. */
  .wdk-sidebar__dot {
    width: 7px;
    height: 7px;
    border-radius: 1.75px;
    flex-shrink: 0;
    display: inline-block;
  }

  /* Nav link base style. */
  .wdk-sidebar__link {
    display: flex;
    align-items: center;
    padding: 6px 14px;
    border-left: 2px solid transparent;
    font-size: 0.8125rem;
    color: var(--text-muted);
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    line-height: 1.4;
    text-decoration: none;
  }

  .wdk-sidebar__link:hover {
    color: var(--text);
    background: var(--surface);
  }

  /* Active state base (non-accented). */
  .wdk-sidebar__link--active {
    color: var(--text);
    background: var(--surface-2);
    font-weight: 500;
  }

  /* Per-accent active variants. */
  .wdk-sidebar__link--violet {
    color: var(--violet);
    background: rgba(122, 47, 242, 0.12);
    border-left-color: var(--violet);
  }
  .wdk-sidebar__link--teal {
    color: var(--teal);
    background: rgba(21, 224, 194, 0.10);
    border-left-color: var(--teal);
  }
  .wdk-sidebar__link--lime {
    color: var(--lime);
    background: rgba(201, 240, 0, 0.10);
    border-left-color: var(--lime);
  }
  .wdk-sidebar__link--orange {
    color: var(--orange);
    background: rgba(247, 146, 14, 0.12);
    border-left-color: var(--orange);
  }
  .wdk-sidebar__link--sky {
    color: var(--sky);
    background: rgba(86, 199, 242, 0.10);
    border-left-color: var(--sky);
  }

  /* Light-mode overrides: lime active link text uses the darker accent-lime
     token (#5a7000) so it reads against the white/light surface. The other
     accents (violet, teal, orange, sky) are already readable in light mode via
     the per-theme --accent-* values resolved by --violet/--teal/etc. */
  :global([data-theme='light']) .wdk-sidebar__link--lime {
    color: var(--accent-lime);
    border-left-color: var(--accent-lime);
    background: rgba(90, 112, 0, 0.08);
  }

  /* Mobile: hide the fixed sidebar (DocLayout drops the left margin to match).
     A mobile nav drawer is a Phase 2 follow-up. */
  @media (max-width: 768px) {
    .wdk-sidebar { display: none; }
  }
</style>
