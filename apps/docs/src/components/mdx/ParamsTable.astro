---
import { resolveApiLink } from '~/config/api-links';

/**
 * ParamsTable.astro - Parameter/option list for a reference symbol.
 *
 * Renders each parameter as a definition-list entry rather than a table row:
 * the name and its type share one line, and the description sits underneath
 * at a readable measure. A three-column table gave the description whatever
 * width the type column left over, which for a full function signature was
 * almost nothing, and forced long signatures to break mid-identifier. Reading
 * a parameter list is a sequential act, not a column-scanning one, so nothing
 * is lost by dropping the column structure.
 *
 * Props:
 *   rows - array of { name, type, desc } objects.
 */
interface Row {
  name: string;
  type: string;
  desc: string;
}

interface Props {
  rows?: Row[];
}

const { rows } = Astro.props;
const hasRows = rows && rows.length > 0;
---

<dl class="wdk-params">
  {hasRows
    ? rows.map((r) => (
        <div class="wdk-params__entry">
          <dt class="wdk-params__head">
            <code class="wdk-params__name">{r.name}</code>
            {resolveApiLink(r.type) ? (
              <a href={resolveApiLink(r.type)?.href} class="wdk-params__type-link">
                <code class="wdk-params__type">{r.type}</code>
              </a>
            ) : (
              <code class="wdk-params__type">{r.type}</code>
            )}
          </dt>
          <dd class="wdk-params__desc">{r.desc}</dd>
        </div>
      ))
    : <slot />
  }
</dl>

<style>
  .wdk-params {
    margin: 16px 0 24px;
  }

  .wdk-params__entry {
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  .wdk-params__entry:first-child {
    padding-top: 0;
  }

  .wdk-params__entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* Name and type share a line and wrap together when the pair is too wide.
     Baseline alignment keeps the smaller type sitting on the name's baseline
     rather than floating against its cap height. */
  .wdk-params__head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* The name carries a neutral chip: enclosure gives it rank without spending
     colour, which is reserved for the type. Sizing and weight reinforce it, so
     the hierarchy holds even when a short name sits beside a long signature. */
  .wdk-params__name {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.14em 0.5em;
  }

  /* Type: accent-coloured, no chip. It reads as an annotation on the name. */
  .wdk-params__type {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--sl-accent, var(--orange));
    background: none;
    border: none;
    padding: 0;
    /* A signature reaches its own spaces first; this only catches a single
       token wider than the line. */
    overflow-wrap: anywhere;
  }

  .wdk-params__type-link {
    text-decoration: none;
  }

  .wdk-params__type-link .wdk-params__type {
    border-bottom: 1px dashed color-mix(in srgb, currentColor 55%, transparent);
    transition: border-color 0.12s ease;
  }

  .wdk-params__type-link:hover .wdk-params__type,
  .wdk-params__type-link:focus-visible .wdk-params__type {
    border-bottom-color: currentColor;
  }

  .wdk-params__type-link:focus-visible {
    outline: 2px solid color-mix(in srgb, currentColor 60%, transparent);
    outline-offset: 3px;
  }

  /* Description. No width cap: the content column's own max-width already
     holds the line to a readable measure. */
  .wdk-params__desc {
    margin: 7px 0 0;
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.65;
  }

  .wdk-params__desc :global(code) {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.85em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.05em 0.3em;
  }

  /* Light mode: --surface-2 resolves to white, which against the near-white
     page leaves the name chip reading as a bare outline. Deepen the fill so
     the chip carries the same weight it does in dark mode. */
  :global([data-theme='light']) .wdk-params__name {
    background: color-mix(in srgb, var(--text) 6%, var(--surface-2));
  }
</style>
