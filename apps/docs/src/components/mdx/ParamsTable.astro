---
/**
 * ParamsTable.astro - Parameter/option table for a reference symbol.
 *
 * Accepts either a `rows` prop (array, avoids JSX in MDX) or a default slot
 * containing <tr> elements so authors can write table rows directly.
 *
 * The `.params-table` styling mirrors the design spec: monospaced name column,
 * tinted type column, and a prose description column. Light and dark both work
 * via CSS variable tokens.
 *
 * Props:
 *   rows - optional array of { name, type, desc } objects. When provided, the
 *          component renders its own <tbody>. When omitted, the slot content
 *          is used as the <tbody> instead (must contain <tr> elements).
 */
interface Row {
  name: string;
  type: string;
  desc: string;
}

interface Props {
  rows?: Row[];
}

const { rows } = Astro.props;
const hasRows = rows && rows.length > 0;
---

<div class="params-table-wrap">
  <table class="params-table">
    <thead>
      <tr>
        <th>Parameter</th>
        <th>Type</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {hasRows
        ? rows.map((r) => (
            <tr>
              <td class="param-name"><code>{r.name}</code></td>
              <td class="param-type"><code>{r.type}</code></td>
              <td class="param-desc">{r.desc}</td>
            </tr>
          ))
        : <slot />
      }
    </tbody>
  </table>
</div>

<style>
  /* Scroll container so the table never overflows on narrow viewports. */
  .params-table-wrap {
    overflow-x: auto;
    margin: 16px 0 24px;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  /* Full-width table, no cell spacing. */
  .params-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  /* Header row. */
  .params-table thead tr {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .params-table th {
    padding: 10px 16px;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    white-space: nowrap;
  }

  /* Body rows. */
  .params-table tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
  }

  .params-table tbody tr:last-child {
    border-bottom: none;
  }

  .params-table tbody tr:hover {
    background: var(--surface);
  }

  .params-table td {
    padding: 10px 16px;
    vertical-align: top;
    color: var(--text-muted);
  }

  /* Parameter name column: monospaced, slightly prominent. Nowrap so
     identifiers never break mid-word; the table-wrap container scrolls
     horizontally instead. */
  .param-name code {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.85em;
    font-weight: 600;
    color: var(--text);
    background: none;
    padding: 0;
    white-space: nowrap;
  }

  /* Type column: accent-tinted monospaced text. */
  .param-type code {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.85em;
    color: var(--sl-accent, var(--orange));
    background: color-mix(in srgb, var(--sl-accent, var(--orange)) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-accent, var(--orange)) 20%, transparent);
    border-radius: 3px;
    padding: 0.05em 0.3em;
    white-space: nowrap;
  }

  /* Description column: lighter prose text. */
  .param-desc {
    color: var(--text-muted);
  }

  /* Inline code in description cells (if any). Background uses the surface-2
     token, which resolves correctly in both light and dark mode. */
  .param-desc :global(code) {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.85em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.05em 0.3em;
  }

  /* Light theme overrides (data-theme="light" set by BaseLayout). */
  :global([data-theme='light']) .params-table thead tr {
    background: var(--surface);
  }

  :global([data-theme='light']) .params-table tbody tr:hover {
    background: var(--surface);
  }
</style>
