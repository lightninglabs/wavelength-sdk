---
/**
 * PromptTabs.astro renders its children (one per tab) behind a tab strip.
 * Tabs are labeled via the data-label attribute on each direct child.
 * Panels hide with hidden attributes so the markdown mirror keeps all three
 * prompts (the converter unwraps them as regular content).
 */
---
<div class="wdk-tabs wdk-prompt-tabs">
  <div class="wdk-tabs__strip" role="tablist"></div>
  <div class="wdk-tabs__panels"><slot /></div>
</div>
<script>
  // Builds the tab strip from the panels' data-label attributes and toggles
  // panel visibility on click. Initialise on astro:page-load so this runs on
  // first load AND after every client-side (view transition) navigation;
  // module scripts do not re-run on client nav. The per-element guard
  // (data-wdk-bound) prevents double-binding on re-init, matching the
  // lifecycle pattern in Header.astro / CodeRail.astro.
  function setupPromptTabs() {
    document.querySelectorAll<HTMLElement>('.wdk-prompt-tabs').forEach((root) => {
      if (root.dataset.wdkBound) return;
      root.dataset.wdkBound = '1';
      const strip = root.querySelector('.wdk-tabs__strip')!;
      const panels = Array.from(root.querySelectorAll<HTMLElement>(':scope > .wdk-tabs__panels > [data-label]'));
      panels.forEach((panel, i) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.role = 'tab';
        btn.textContent = panel.dataset.label ?? `Tab ${i + 1}`;
        btn.setAttribute('aria-selected', String(i === 0));
        if (i > 0) panel.hidden = true;
        btn.addEventListener('click', () => {
          panels.forEach((p, j) => { p.hidden = j !== i; });
          strip.querySelectorAll('button').forEach((b, j) => b.setAttribute('aria-selected', String(j === i)));
        });
        strip.appendChild(btn);
      });
    });
  }
  document.addEventListener('astro:page-load', setupPromptTabs);
</script>
