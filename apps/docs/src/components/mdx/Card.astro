---
// A content card (replaces Starlight's <Card>). Styling ported from
// design-mockups/r4-final/styles.css (.related-card rules). Class is .wdk-card.
// When `href` is set the whole card is a link (use plain text in the slot;
// markdown link syntax inside MDX component slots is not parsed).
interface Props {
  title: string;
  href?: string;
  icon?: string;
}
const { title, href } = Astro.props;
const Tag = href ? 'a' : 'article';
---
<Tag class="wdk-card" {...(href ? { href } : {})}>
  <h3 class="wdk-card__title">{title}</h3>
  <div class="wdk-card__body"><slot /></div>
  {href && <span class="wdk-card__cta">Read the guide &rarr;</span>}
</Tag>

<style>
  .wdk-card {
    background: var(--surface, #1c1c21);
    border: 1px solid var(--border, #303037);
    border-radius: 10px;
    padding: 16px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: border-color 0.15s, transform 0.15s;
  }

  .wdk-card:hover {
    border-color: var(--border-2, #44444d);
    transform: translateY(-2px);
  }

  .wdk-card__title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text, #f5f5f7);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .wdk-card__body {
    font-size: 0.875rem;
    color: var(--text-muted, #b6b6c0);
    line-height: 1.6;
  }

  a.wdk-card {
    color: inherit;
    cursor: pointer;
  }

  .wdk-card__cta {
    margin-top: auto;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-dim, #8c8c96);
    transition: color 0.15s;
  }

  a.wdk-card:hover .wdk-card__cta {
    color: var(--sl-accent, var(--accent-teal));
  }
</style>
