---
import { resolveApiLink } from '~/config/api-links';

/**
 * Returns.astro - Return value block for a reference symbol.
 *
 * Shows the return type as an accent-tinted label and uses the default slot
 * for a prose description of what the returned value represents.
 *
 * Props:
 *   type - the return type string (rendered monospaced with orange tint).
 */
interface Props {
  type: string;
}

const { type } = Astro.props;
---

<div class="wdk-returns">
  <span class="wdk-returns__label">Returns</span>
  {resolveApiLink(type) ? (
    <a class="wdk-returns__type-link" href={resolveApiLink(type)?.href}>
      <code class="wdk-returns__type">{type}</code>
    </a>
  ) : (
    <code class="wdk-returns__type">{type}</code>
  )}
  <div class="wdk-returns__desc">
    <slot />
  </div>
</div>

<style>
  /* Outer block with a subtle left border that echoes the accent color. */
  .wdk-returns {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    margin: 16px 0 24px;
    padding: 12px 16px;
    background: color-mix(in srgb, var(--sl-accent, var(--orange)) 6%, transparent);
    border-left: 3px solid var(--sl-accent, var(--orange));
    border-radius: 0 6px 6px 0;
  }

  /* Small uppercase "Returns" label. */
  .wdk-returns__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sl-accent, var(--orange));
    flex-shrink: 0;
  }

  /* Return type: monospaced, accent-colored. */
  .wdk-returns__type {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sl-accent, var(--orange));
    background: color-mix(in srgb, var(--sl-accent, var(--orange)) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-accent, var(--orange)) 25%, transparent);
    border-radius: 3px;
    padding: 0.1em 0.4em;
    flex-shrink: 0;
  }

  .wdk-returns__type-link {
    text-decoration: none;
  }

  .wdk-returns__type-link .wdk-returns__type {
    border-bottom: 1px dashed color-mix(in srgb, currentColor 55%, transparent);
    transition: border-color 0.12s ease;
  }

  .wdk-returns__type-link:hover .wdk-returns__type,
  .wdk-returns__type-link:focus-visible .wdk-returns__type {
    border-bottom-color: currentColor;
  }

  .wdk-returns__type-link:focus-visible {
    outline: 2px solid color-mix(in srgb, currentColor 60%, transparent);
    outline-offset: 3px;
  }

  /* Description prose below the type label. */
  .wdk-returns__desc {
    width: 100%;
    margin-top: 6px;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .wdk-returns__desc :global(p) {
    margin: 0;
  }

  /* Inline code in the description slot. Background uses the surface-2 token,
     which resolves correctly in both light and dark mode without a hardcoded fallback. */
  .wdk-returns__desc :global(:not(.expressive-code) code) {
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    font-size: 0.85em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.05em 0.3em;
  }
</style>
