---
import { mermaidInitDirective } from '~/config/mermaid.ts';

/** Mermaid diagram source. Client rendering is handled by astro-mermaid. */
interface Props {
  chart: string;
}
const { chart } = Astro.props;
const source = `${mermaidInitDirective}\n${chart.trim()}`;
---
<div class="wdk-mermaid">
  <pre class="mermaid">{source}</pre>
</div>
