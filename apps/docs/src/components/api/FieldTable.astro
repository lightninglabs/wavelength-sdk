---
/**
 * FieldTable renders the fields of one request or response message as a
 * definition list: the field name and its type share one line, with the
 * description underneath at a readable measure. This matches ParamsTable on
 * the package reference pages; see the note there for why a three-column
 * table is the wrong shape for this content.
 *
 * A message-typed field deep links to the on-page section for that type when
 * it is rendered here (linkedTypes), so the reader can jump from a field
 * straight to its shape. oneof members carry a small group badge, proto3
 * `optional` fields carry an "optional" badge, and repeated fields render
 * their type as "repeated X".
 */
import type { FieldDoc } from '~/data/api/schema';
import ProtoText from './ProtoText.astro';

interface Props {
  fields: FieldDoc[];
  /** Type names rendered on this page, so type cells can deep-link. */
  linkedTypes: Set<string>;
}
const { fields, linkedTypes } = Astro.props;

const typeLabel = (f: FieldDoc): string => `${f.repeated ? 'repeated ' : ''}${f.type}`;

// Proto comments separate paragraphs with blank lines; within a paragraph the
// text is hard-wrapped. Collapse wraps to spaces and keep paragraph breaks so
// a multi-paragraph field comment stays readable.
const paragraphs = (comment: string): string[] =>
  comment
    .split(/\n\s*\n/)
    .map((p) => p.replace(/\s*\n\s*/g, ' ').trim())
    .filter(Boolean);
---
{fields.length === 0 ? (
  <p class="wdk-fields__empty">This message has no fields.</p>
) : (
  <dl class="wdk-fields">
    {fields.map((f) => (
      <div class="wdk-fields__entry" data-field-row={f.name}>
        <dt class="wdk-fields__head">
          <code class="wdk-fields__name">{f.name}</code>
          {linkedTypes.has(f.type) ? (
            <a href={`#${f.type}`} class="wdk-fields__typelink">
              <code class="wdk-fields__type">{typeLabel(f)}</code>
            </a>
          ) : (
            <code class="wdk-fields__type">{typeLabel(f)}</code>
          )}
          {f.oneof && (
            <span class="wdk-fields__badge" title={`oneof ${f.oneof}`}>
              oneof {f.oneof}
            </span>
          )}
          {f.optional && (
            <span class="wdk-fields__badge" title="Proto3 optional field">
              optional
            </span>
          )}
        </dt>
        <dd class="wdk-fields__desc">
          {paragraphs(f.comment).map((p) => (
            <p><ProtoText text={p} /></p>
          ))}
        </dd>
      </div>
    ))}
  </dl>
)}

<style>
  .wdk-fields {
    margin: 16px 0 24px;
  }

  .wdk-fields__entry {
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  .wdk-fields__entry:first-child {
    padding-top: 0;
  }

  .wdk-fields__entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* Name, type, and any badges share a line and wrap together. */
  .wdk-fields__head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* The name carries a neutral chip: enclosure gives it rank without spending
     colour, which is reserved for the type. */
  .wdk-fields__name {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.14em 0.5em;
  }

  /* Type: accent-coloured, no chip, reading as an annotation on the name. */
  .wdk-fields__type {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--sl-accent, var(--orange));
    overflow-wrap: anywhere;
  }

  .wdk-fields__typelink {
    text-decoration: none;
  }
  .wdk-fields__typelink .wdk-fields__type {
    border-bottom: 1px dashed color-mix(in srgb, var(--sl-accent, var(--orange)) 45%, transparent);
    transition: border-color 0.12s ease;
  }
  .wdk-fields__typelink:hover .wdk-fields__type,
  .wdk-fields__typelink:focus-visible .wdk-fields__type {
    border-bottom-color: var(--sl-accent, var(--orange));
  }
  .wdk-fields__typelink:focus-visible {
    outline: 2px solid color-mix(in srgb, currentColor 60%, transparent);
    outline-offset: 3px;
  }

  /* oneof/optional badge: a quiet pill trailing the type. */
  .wdk-fields__badge {
    padding: 1px 7px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-dim);
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: 999px;
  }

  /* Description. No width cap: the content column's own max-width already
     holds the line to a readable measure. */
  .wdk-fields__desc {
    margin: 7px 0 0;
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.65;
  }
  .wdk-fields__desc p {
    margin: 0;
  }
  .wdk-fields__desc p + p {
    margin-top: 8px;
  }

  /* Light mode: --surface-2 resolves to white, which against the near-white
     page leaves the name chip reading as a bare outline. Deepen the fill so
     the chip carries the same weight it does in dark mode. */
  :global([data-theme='light']) .wdk-fields__name {
    background: color-mix(in srgb, var(--text) 6%, var(--surface-2));
  }

  /* Empty message: a quiet note in place of the list. */
  .wdk-fields__empty {
    margin: 0;
    padding: 16px 18px;
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 12px;
    color: var(--text-dim);
    font-size: 0.875rem;
    font-style: italic;
  }
</style>
