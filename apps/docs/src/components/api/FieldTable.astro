---
/**
 * FieldTable renders the fields of one request or response message as a
 * three-column table (field, type, description). A message-typed cell deep
 * links to the on-page section for that type when it is rendered here
 * (linkedTypes), so the reader can jump from a field straight to its shape.
 * oneof members carry a small group badge, proto3 `optional` fields carry an
 * "optional" badge, and repeated fields render their type as "repeated X".
 */
import type { FieldDoc } from '~/data/api/schema';
import ProtoText from './ProtoText.astro';

interface Props {
  fields: FieldDoc[];
  /** Type names rendered on this page, so type cells can deep-link. */
  linkedTypes: Set<string>;
}
const { fields, linkedTypes } = Astro.props;

const typeLabel = (f: FieldDoc): string => `${f.repeated ? 'repeated ' : ''}${f.type}`;

// Proto comments separate paragraphs with blank lines; within a paragraph the
// text is hard-wrapped. Collapse wraps to spaces and keep paragraph breaks so
// a multi-paragraph field comment stays readable inside the cell.
const paragraphs = (comment: string): string[] =>
  comment
    .split(/\n\s*\n/)
    .map((p) => p.replace(/\s*\n\s*/g, ' ').trim())
    .filter(Boolean);
---
{fields.length === 0 ? (
  <p class="wdk-fields__empty">This message has no fields.</p>
) : (
  <div class="wdk-fields__wrap">
    <table class="wdk-fields">
      <thead>
        <tr>
          <th>Field</th>
          <th>Type</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {fields.map((f) => (
          <tr data-field-row={f.name}>
            <td class="wdk-fields__name">
              <code>{f.name}</code>
              {f.oneof && (
                <span class="wdk-fields__badge" title={`oneof ${f.oneof}`}>
                  oneof {f.oneof}
                </span>
              )}
              {f.optional && (
                <span class="wdk-fields__badge" title="Proto3 optional field">
                  optional
                </span>
              )}
            </td>
            <td class="wdk-fields__type">
              {linkedTypes.has(f.type) ? (
                <a href={`#${f.type}`} class="wdk-fields__typelink">
                  <code>{typeLabel(f)}</code>
                </a>
              ) : (
                <code>{typeLabel(f)}</code>
              )}
            </td>
            <td class="wdk-fields__desc">
              {paragraphs(f.comment).map((p) => (
                <p><ProtoText text={p} /></p>
              ))}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

<style>
  /* Horizontal scroll guard for the widest field/type combinations at small
     widths, without forcing the whole page to scroll. */
  .wdk-fields__wrap {
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
  }

  .wdk-fields__wrap::-webkit-scrollbar { height: 5px; }
  .wdk-fields__wrap::-webkit-scrollbar-track { background: transparent; }
  .wdk-fields__wrap::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .wdk-fields {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    min-width: 520px;
  }

  /* Column header: small uppercase eyebrow, matching the site's table motif. */
  .wdk-fields thead th {
    text-align: left;
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 12px 16px;
    background: color-mix(in srgb, var(--surface-2) 60%, transparent);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .wdk-fields tbody td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .wdk-fields tbody tr:last-child td {
    border-bottom: none;
  }

  /* Row hover: a faint accent wash tying the tables to the page accent. */
  .wdk-fields tbody tr {
    transition: background 0.12s ease;
  }
  .wdk-fields tbody tr:hover {
    background: color-mix(in srgb, var(--sl-accent, var(--orange)) 5%, transparent);
  }

  /* Field name column: monospace identifier + an optional badge below. */
  .wdk-fields__name {
    white-space: nowrap;
  }
  .wdk-fields__name code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
  }

  /* oneof/optional badge: small pill under the field name. */
  .wdk-fields__badge {
    display: block;
    margin-top: 6px;
    width: fit-content;
    padding: 1px 7px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-dim);
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: 999px;
  }

  /* Type column: monospace type name; linked types read in the page accent. */
  .wdk-fields__type code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .wdk-fields__typelink {
    text-decoration: none;
  }
  .wdk-fields__typelink code {
    color: var(--sl-accent, var(--orange));
    border-bottom: 1px dashed color-mix(in srgb, var(--sl-accent, var(--orange)) 45%, transparent);
    transition: border-color 0.12s ease;
  }
  .wdk-fields__typelink:hover code {
    border-bottom-color: var(--sl-accent, var(--orange));
  }

  /* Description column: muted prose, tight paragraph rhythm. */
  .wdk-fields__desc {
    color: var(--text-muted);
    line-height: 1.55;
    min-width: 240px;
  }
  .wdk-fields__desc p {
    margin: 0;
  }
  .wdk-fields__desc p + p {
    margin-top: 8px;
  }

  /* Empty message: a quiet note in place of the table. */
  .wdk-fields__empty {
    margin: 0;
    padding: 16px 18px;
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 12px;
    color: var(--text-dim);
    font-size: 0.875rem;
    font-style: italic;
  }
</style>
