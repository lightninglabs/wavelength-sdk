---
/**
 * ReferenceLinksBand.astro - compact cross-link band to the API and CLI slices.
 * Two cards, not a hero: a small eyebrow + heading followed by a two-column
 * row of link cards, styled per the existing home section idiom (see
 * LayersBand.astro / ConceptsStrip.astro for the eyebrow + card pattern).
 */
---

<section class="wdk-refs" aria-labelledby="wdk-refs-heading">
  <div class="wdk-refs__eyebrow">
    <div class="wdk-refs__eyebrow-sq" aria-hidden="true"></div>
    <span class="wdk-refs__eyebrow-text">Beyond the browser</span>
    <div class="wdk-refs__eyebrow-line" aria-hidden="true"></div>
  </div>
  <h2 id="wdk-refs-heading" class="wdk-refs__heading">Reach the wallet daemon directly.</h2>
  <p class="wdk-refs__sub">The SDK is one way in. The daemon underneath also speaks gRPC, REST, and a command line.</p>

  <div class="wdk-refs__grid">
    <a href="/api/" class="wdk-ref wdk-ref--sky">
      <div class="wdk-ref__accent" aria-hidden="true"></div>
      <h3 class="wdk-ref__title">API reference</h3>
      <p class="wdk-ref__desc">Integrate remotely over gRPC and REST.</p>
      <span class="wdk-ref__arrow" aria-hidden="true">&#8594;</span>
    </a>
    <a href="/cli/" class="wdk-ref wdk-ref--orange">
      <div class="wdk-ref__accent" aria-hidden="true"></div>
      <h3 class="wdk-ref__title">CLI reference</h3>
      <p class="wdk-ref__desc">Automate the wallet from the command line.</p>
      <span class="wdk-ref__arrow" aria-hidden="true">&#8594;</span>
    </a>
  </div>
</section>

<style>
  .wdk-refs {
    padding: 70px 80px 100px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Eyebrow. */
  .wdk-refs__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .wdk-refs__eyebrow-sq {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--sky);
    flex-shrink: 0;
  }
  .wdk-refs__eyebrow-text {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .wdk-refs__eyebrow-line {
    flex: 1;
    height: 1px;
    background: var(--border);
    max-width: 60px;
  }

  .wdk-refs__heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .wdk-refs__sub {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    line-height: 1.65;
  }

  /* Two-column card row. */
  .wdk-refs__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .wdk-ref {
    display: block;
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 28px;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .wdk-ref:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
  }

  /* Coloured top accent line, per card. */
  .wdk-ref__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
  }
  .wdk-ref--sky .wdk-ref__accent    { background: var(--sky); }
  .wdk-ref--orange .wdk-ref__accent { background: var(--orange); }

  .wdk-ref__title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  .wdk-ref__desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
    padding-right: 1.5rem;
  }

  .wdk-ref__arrow {
    position: absolute;
    bottom: 22px;
    right: 24px;
    font-size: 0.8125rem;
    color: var(--text-dim);
    opacity: 0;
    transition: opacity 0.15s, color 0.15s, transform 0.15s;
  }
  .wdk-ref--sky:hover .wdk-ref__arrow {
    opacity: 1;
    color: var(--sky);
    transform: translateX(3px);
  }
  .wdk-ref--orange:hover .wdk-ref__arrow {
    opacity: 1;
    color: var(--orange);
    transform: translateX(3px);
  }

  /* Mobile: single-column stack, tighter padding. */
  @media (max-width: 768px) {
    .wdk-refs { padding: 50px 20px 70px; }
    .wdk-refs__grid { grid-template-columns: 1fr; }
    .wdk-ref__arrow { opacity: 1; color: var(--text-dim); }
  }
</style>
