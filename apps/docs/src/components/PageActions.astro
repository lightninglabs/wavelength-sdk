---
/**
 * PageActions.astro renders a single trigger, floated beside the page h1,
 * that opens a menu of agent-facing actions: copy or view the markdown
 * mirror, copy its URL, or open it in an AI assistant. The mirror URL is
 * the current path with a .md suffix; mirrors exist only in built output,
 * so the copy rows report failure in `astro dev`.
 */
import { SITE_URL } from '~/config/site';

const path = Astro.url.pathname.replace(/\/$/, '');
const mdPath = `${path}.md`;
const mdUrl = `${SITE_URL}${mdPath}`;
const prompt = encodeURIComponent(`Read ${mdUrl}, I want to ask questions about it.`);
---

<div class="wdk-page-actions" data-md-path={mdPath} data-md-url={mdUrl} data-pagefind-ignore>
  <button
    type="button"
    class="wdk-page-actions__trigger"
    aria-haspopup="menu"
    aria-expanded="false"
  >
    <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 2.2 9.15 5.9 12.8 7l-3.65 1.1L8 11.8 6.85 8.1 3.2 7l3.65-1.1L8 2.2Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" />
      <path d="M12.7 10.2 13.2 11.7 14.6 12.2 13.2 12.7 12.7 14.2 12.2 12.7 10.8 12.2 12.2 11.7 12.7 10.2Z" stroke="currentColor" stroke-width="1" stroke-linejoin="round" />
    </svg>
    For agents
  </button>

  <div class="wdk-page-actions__menu" role="menu">
    <button type="button" class="wdk-page-actions__row wdk-page-actions__copy-md" role="menuitem">
      <span class="wdk-page-actions__row-icon">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="5.5" y="5.5" width="8" height="8.5" rx="1.5" stroke="currentColor" stroke-width="1.3" />
          <path d="M3.5 10V3.75A1.25 1.25 0 0 1 4.75 2.5H9.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
        </svg>
      </span>
      <span class="wdk-page-actions__row-text">
        <span class="wdk-page-actions__row-title" data-default="Copy as Markdown">Copy as Markdown</span>
        <span class="wdk-page-actions__row-desc">Paste the raw source anywhere</span>
      </span>
    </button>

    <button type="button" class="wdk-page-actions__row wdk-page-actions__copy-url" role="menuitem">
      <span class="wdk-page-actions__row-icon">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6.5 9.5 9.5 6.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          <path d="M7 4.5 8.2 3.3a2.2 2.2 0 0 1 3.1 3.1L10 7.6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          <path d="M9 11.5 7.8 12.7a2.2 2.2 0 0 1-3.1-3.1L6 8.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
        </svg>
      </span>
      <span class="wdk-page-actions__row-text">
        <span class="wdk-page-actions__row-title" data-default="Copy URL to Markdown">Copy URL to Markdown</span>
        <span class="wdk-page-actions__row-desc">Share the .md link</span>
      </span>
    </button>

    <a class="wdk-page-actions__row" role="menuitem" href={mdPath}>
      <span class="wdk-page-actions__row-icon">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M4.5 2h4.5L12.5 5.5V13a1 1 0 0 1-1 1h-7a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round" />
          <path d="M9 2v3.5h3.5" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="wdk-page-actions__row-text">
        <span class="wdk-page-actions__row-title">View as Markdown</span>
        <span class="wdk-page-actions__row-desc">Open the plain-text mirror</span>
      </span>
    </a>

    <span class="wdk-page-actions__divider" role="separator"></span>

    <a class="wdk-page-actions__row" role="menuitem" href={`https://claude.ai/new?q=${prompt}`} target="_blank" rel="noopener">
      <span class="wdk-page-actions__row-icon">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 2.5 9.6 6.4 13.5 8l-3.9 1.6L8 13.5l-1.6-3.9L2.5 8l3.9-1.6L8 2.5Z" stroke="currentColor" stroke-width="1.15" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="wdk-page-actions__row-text">
        <span class="wdk-page-actions__row-title">Open in Claude</span>
        <span class="wdk-page-actions__row-desc">Ask questions about this page</span>
      </span>
    </a>

    <a class="wdk-page-actions__row" role="menuitem" href={`https://chatgpt.com/?prompt=${prompt}`} target="_blank" rel="noopener">
      <span class="wdk-page-actions__row-icon">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 2.75a5.25 5.25 0 1 0 0 10.5 5.25 5.25 0 0 0 0-10.5Z" stroke="currentColor" stroke-width="1.15" />
          <path d="M8 5.25v2.75l1.9 1.1" stroke="currentColor" stroke-width="1.15" stroke-linecap="round" />
        </svg>
      </span>
      <span class="wdk-page-actions__row-text">
        <span class="wdk-page-actions__row-title">Open in ChatGPT</span>
        <span class="wdk-page-actions__row-desc">Ask questions about this page</span>
      </span>
    </a>
  </div>
</div>

<script>
  // Bind on astro:page-load so this runs on first load AND after every
  // client-side (view transition) navigation; module scripts do not re-run
  // on client nav. The per-element guard (data-wdk-bound) prevents
  // double-binding on re-init, matching the lifecycle pattern in
  // Header.astro / CodeRail.astro.
  function setupPageActions() {
    document.querySelectorAll<HTMLElement>('.wdk-page-actions').forEach((root) => {
      if (root.dataset.wdkBound) return;
      root.dataset.wdkBound = '1';

      const trigger = root.querySelector<HTMLButtonElement>('.wdk-page-actions__trigger')!;
      const menu = root.querySelector<HTMLElement>('.wdk-page-actions__menu')!;

      function openMenu() {
        menu.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
      function closeMenu() {
        menu.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      }

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        if (menu.classList.contains('is-open')) closeMenu();
        else openMenu();
      });
      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) closeMenu();
      });
      root.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeMenu();
          trigger.focus();
        }
      });

      function flashRow(row: HTMLElement, text: string, ok: boolean) {
        const title = row.querySelector<HTMLElement>('.wdk-page-actions__row-title')!;
        title.textContent = text;
        row.classList.add(ok ? 'is-done' : 'is-error');
        setTimeout(() => {
          title.textContent = title.dataset.default!;
          row.classList.remove('is-done', 'is-error');
          if (ok) closeMenu();
        }, ok ? 700 : 1600);
      }

      const copyMd = root.querySelector<HTMLButtonElement>('.wdk-page-actions__copy-md')!;
      copyMd.addEventListener('click', async () => {
        try {
          const res = await fetch(root.dataset.mdPath!);
          if (!res.ok) throw new Error(String(res.status));
          await navigator.clipboard.writeText(await res.text());
          flashRow(copyMd, 'Copied', true);
        } catch (err) {
          console.error('wdk-page-actions: copy as markdown failed', err);
          flashRow(copyMd, 'Unavailable', false);
        }
      });

      const copyUrl = root.querySelector<HTMLButtonElement>('.wdk-page-actions__copy-url')!;
      copyUrl.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(root.dataset.mdUrl!);
          flashRow(copyUrl, 'Copied', true);
        } catch (err) {
          console.error('wdk-page-actions: copy url to markdown failed', err);
          flashRow(copyUrl, 'Unavailable', false);
        }
      });
    });
  }
  document.addEventListener('astro:page-load', setupPageActions);
</script>

<style>
  /* A single trigger floated beside the h1; a popover menu carries every
     action so the title row stays uncluttered at rest. */
  .wdk-page-actions {
    position: relative;
    flex-shrink: 0;
  }

  .wdk-page-actions__trigger {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    white-space: nowrap;
    appearance: none;
    background: color-mix(in srgb, var(--sl-accent, var(--teal)) 10%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--sl-accent, var(--teal)) 35%, var(--border));
    border-radius: 999px;
    padding: 7px 14px 7px 12px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sl-accent, var(--teal));
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .wdk-page-actions__trigger:hover,
  .wdk-page-actions__trigger[aria-expanded='true'] {
    background: color-mix(in srgb, var(--sl-accent, var(--teal)) 18%, var(--surface));
    border-color: var(--sl-accent, var(--teal));
  }

  .wdk-page-actions__trigger:focus-visible {
    outline: 2px solid var(--sl-accent, var(--teal));
    outline-offset: 2px;
  }

  .wdk-page-actions__menu {
    display: none;
    flex-direction: column;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 268px;
    background: var(--surface-2);
    border: 1px solid var(--border-2);
    border-radius: 14px;
    box-shadow: 0 20px 48px rgb(0 0 0 / 0.35);
    padding: 8px;
    z-index: 20;
  }

  .wdk-page-actions__menu.is-open {
    display: flex;
  }

  .wdk-page-actions__row {
    display: flex;
    align-items: center;
    gap: 11px;
    appearance: none;
    background: transparent;
    border: none;
    border-radius: 9px;
    padding: 9px 10px;
    text-align: left;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.12s ease;
  }

  .wdk-page-actions__row:hover {
    background: var(--surface-3);
    /* Beats the doc/guide prose column's global `a:hover { text-decoration:
       underline }` rule on specificity; these rows are chrome, not prose. */
    text-decoration: none;
  }

  .wdk-page-actions__row:focus-visible {
    outline: 2px solid var(--sl-accent, var(--teal));
    outline-offset: -2px;
  }

  .wdk-page-actions__row-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-dim);
  }

  .wdk-page-actions__row-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .wdk-page-actions__row-title {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text);
  }

  .wdk-page-actions__row-desc {
    font-family: var(--font-body);
    font-size: 0.71rem;
    color: var(--text-dim);
  }

  .wdk-page-actions__divider {
    height: 1px;
    background: var(--border);
    margin: 5px 4px;
  }

  /* Copy feedback: the row title borrows the section accent for success, a
     dimmer neutral tone for the (dev-only) fetch failure case. */
  .wdk-page-actions__row.is-done .wdk-page-actions__row-title {
    color: var(--sl-accent, var(--teal));
  }

  .wdk-page-actions__row.is-error .wdk-page-actions__row-title {
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    .wdk-page-actions__menu {
      width: 240px;
    }
  }
</style>
