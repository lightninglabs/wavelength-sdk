---
/**
 * ScrollProgress.astro - Thin gradient bar pinned under the header that fills
 * as the reader scrolls the page. Mounted once in BaseLayout so it is present
 * on every page.
 *
 * Styling ported from design-mockups/r4-final/styles.css (.scroll-progress).
 *
 * Lifecycle matches CodeRail.astro: init on astro:page-load (module scripts
 * do not re-run on client-side, view-transition navigations), guard with a
 * per-element flag so re-init is idempotent, and tear down the scroll
 * listener on a self-removing astro:before-swap so listeners do not
 * accumulate across navigations.
 */
---
<div
  class="wdk-scroll-progress"
  role="progressbar"
  aria-label="Page scroll progress"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
></div>

<script>
  function setupScrollProgress() {
    const bar = document.querySelector('.wdk-scroll-progress');
    if (!(bar instanceof HTMLElement) || bar.dataset.wdkBound) return;
    bar.dataset.wdkBound = '1';

    function onScroll() {
      const doc = document.documentElement;
      const scrollable = doc.scrollHeight - doc.clientHeight;
      const pct = scrollable > 0 ? (doc.scrollTop / scrollable) * 100 : 0;
      const clamped = Math.min(100, Math.max(0, pct));
      bar.style.width = `${clamped}%`;
      bar.setAttribute('aria-valuenow', String(Math.round(clamped)));
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Tear down the scroll listener before the next view-transition swap so
    // it does not accumulate across client-side navigations. The teardown
    // removes itself from astro:before-swap so teardown listeners do not
    // stack up either.
    function teardown() {
      window.removeEventListener('scroll', onScroll);
      delete bar.dataset.wdkBound;
      document.removeEventListener('astro:before-swap', teardown);
    }
    document.addEventListener('astro:before-swap', teardown);
  }
  document.addEventListener('astro:page-load', setupScrollProgress);
</script>

<style>
  /* Fixed gradient bar under the header; width is driven by the script. */
  .wdk-scroll-progress {
    position: fixed;
    top: var(--header-height);
    left: 0;
    height: 2px;
    width: 0;
    background: linear-gradient(90deg, var(--violet), var(--teal));
    z-index: 200;
    transition: width 0.1s linear;
  }
</style>
