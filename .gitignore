node_modules/
dist/
test-results/
*.tsbuildinfo
.DS_Store
# public/ is an ephemeral staging area for runtime assets; never committed.
apps/*/public/
# _headers is a static host config file (Netlify/Cloudflare Pages), not a runtime asset.
!apps/docs/public/
!apps/docs/public/_headers
# The demo's icons and manifest are committed static assets rather than staged
# runtime output. Git cannot re-include a path whose parent directory is
# excluded, so un-ignore the directory, re-exclude its contents, then allow the
# two static entries back in. wasm-local.sh only clears public/runtime and the
# named legacy files, so staging the runtime leaves them alone.
!apps/web-wallet-demo/public/
apps/web-wallet-demo/public/*
!apps/web-wallet-demo/public/icons/
!apps/web-wallet-demo/public/manifest.json

# Superpowers SDD scratch (briefs, reports, ledger, review diffs).
.superpowers/

# Local plans and specs; kept out of the repo, discarded after implementation.
docs/superpowers/

# Per-checkout dev-server launch config: its port depends on what else is
# already listening locally, so it never transfers between worktrees. Only this
# one file is ignored; .claude/ is not ignored wholesale.
.claude/launch.json

# Staged gomobile bindings and native build output for the RN transport;
# rebuilt from wavelength by packages/react-native/scripts/fetch-bindings.sh.
packages/react-native/android/libs/
packages/react-native/ios/Wavewalletdk.xcframework/
packages/react-native/android/build/
