{
  "name": "wavelength-sdk",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "pnpm -r run typecheck && tsc -p scripts/tsconfig.json",
    "check:packages": "pnpm -r --filter \"./packages/*\" exec publint && pnpm -r --filter \"./packages/*\" exec attw --pack . --profile esm-only",
    "gen:types": "node scripts/gen-types.mts",
    "gen:api-docs": "node scripts/gen-api-docs.mts",
    "test:api-docs": "node --test scripts/api-docs/extract.test.mts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/node": "^24.0.0",
    "protobufjs": "^7.4.0",
    "publint": "^0.3.21",
    "typescript": "^5.7.2",
    "yaml": "^2.6.0"
  }
}
